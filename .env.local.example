# Copy this file to .env.local and fill in real values.

# Resend API key for contact form delivery
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL (used for canonical URLs, sitemap, structured data)
NEXT_PUBLIC_SITE_URL=https://code4u.app

# Contact form destination email
CONTACT_TO_EMAIL=Ronald@code4u.app

# Verified sender domain for Resend (must match domain configured in Resend dashboard)
CONTACT_FROM_EMAIL=noreply@code4u.app
